    <script>
        // ========== DADOS E FUNÇÕES DE PREÇO ORIGINAL (CATÁLOGO) ==========
        function calcularPrecoPorFolhaOriginal(tipo, folhas) {
            if (tipo === 'preta-frente') {
                if (folhas <= 50) return 0.60;
                if (folhas <= 200) return 0.55;
                return 0.50;
            }
            if (tipo === 'preta-fv') {
                if (folhas <= 50) return 0.50;
                if (folhas <= 200) return 0.45;
                return 0.40;
            }
            if (tipo === 'colorida-frente') {
                if (folhas <= 50) return 0.95;
                if (folhas <= 200) return 0.85;
                return 0.75;
            }
            if (tipo === 'colorida-fv') {
                if (folhas <= 50) return 0.80;
                if (folhas <= 200) return 0.75;
                return 0.70;
            }
            return 0.60;
        }

        function calcularPrecoApostilaOriginal(tipo, folhas) {
            const precoPorFolha = calcularPrecoPorFolhaOriginal(tipo, folhas);
            const precoImpressao = precoPorFolha * folhas;
            const encadernacao = 7.00;
            const precoUnitario = precoImpressao + encadernacao;
            return { precoPorFolha, precoImpressao, precoUnitario, encadernacao };
        }

        const TIPOS = [
            { id: 'preta-frente', nome: 'Preta - Só Frente', classe: 'preta' },
            { id: 'preta-fv', nome: 'Preta - Frente e Verso', classe: 'preta' },
            { id: 'colorida-frente', nome: 'Colorida - Só Frente', classe: 'colorida' },
            { id: 'colorida-fv', nome: 'Colorida - Frente e Verso', classe: 'colorida' }
        ];
        const quantidadesFolhas = [30, 50, 100, 150, 200, 300, 400];
        let apostilas = [];
        TIPOS.forEach(tipo => {
            quantidadesFolhas.forEach(folhas => {
                const preco = calcularPrecoApostilaOriginal(tipo.id, folhas);
                apostilas.push({
                    id: `${tipo.id}-${folhas}`,
                    tipo: tipo.id,
                    tipoNome: tipo.nome,
                    classe: tipo.classe,
                    folhas: folhas,
                    precoComEncadernacao: preco.precoUnitario,
                    precoImpressao: preco.precoImpressao,
                    precoPorFolha: preco.precoPorFolha,
                });
            });
        });

        // ========== LÓGICA DA CALCULADORA COM DESCONTOS ==========
        function calcularPrecoPorFolhaComDesconto(tipo, numOpcoes) {
            const basePreto = 0.75;
            const baseColorido = 0.90;
            const desconto = 0.25;
            let precoBase = tipo.includes('preta') ? basePreto : baseColorido;
            let precoFinal = precoBase - (numOpcoes * desconto);
            const piso = tipo.includes('preta') ? 0.50 : 0.65;
            return Math.max(precoFinal, piso);
        }

        function calcularApostilaCustom(tipo, folhas, quantidade, numOpcoes) {
            const precoPorFolha = calcularPrecoPorFolhaComDesconto(tipo, numOpcoes);
            const precoImpressao = precoPorFolha * folhas;
            const encadernacao = 7.00;
            const precoUnitario = precoImpressao + encadernacao;
            const precoTotal = precoUnitario * quantidade;
            return { precoPorFolha, precoImpressao, precoUnitario, precoTotal, encadernacao, folhas, tipo, quantidade, numOpcoes };
        }

        // ========== VARIÁVEIS GLOBAIS ==========
        let carrinho = []; // itens podem ser do catálogo ou custom
        let modalAberto = false;

        // ========== FUNÇÕES AUXILIARES ==========
        function mostrarFeedback(msg) {
            const div = document.createElement('div');
            div.style.cssText = 'position:fixed; bottom:20px; right:20px; background:#4caf50; color:white; padding:1rem 1.5rem; border-radius:8px; z-index:3000;';
            div.innerHTML = `<i class="fas fa-check-circle"></i> ${msg}`;
            document.body.appendChild(div);
            setTimeout(() => div.remove(), 3000);
        }

        function abrirModal() { document.getElementById('cart-modal').style.display = 'flex'; modalAberto = true; }
        function fecharModal() { document.getElementById('cart-modal').style.display = 'none'; modalAberto = false; }

        // ========== RENDER CATÁLOGO ==========
        function renderApostilas(items) {
            const container = document.getElementById('apostilas-container');
            if (!container) return;
            container.innerHTML = '';
            if (items.length === 0) { container.innerHTML = '<p style="grid-column:1/-1; text-align:center;">Nenhuma apostila encontrada.</p>'; return; }
            items.forEach(ap => {
                const card = document.createElement('div');
                card.className = 'apostila-card';
                const obsHtml = ap.classe === 'preta' ? `<div class="observacao-capa"><strong><i class="fas fa-info-circle"></i> Observação:</strong> Se sua capa estiver colorida, faremos ela colorida e demais páginas na cor preta.</div>` : '';
                card.innerHTML = `
                    <div class="apostila-header ${ap.classe}"><h3>${ap.tipoNome}</h3><p>${ap.folhas} folhas</p></div>
                    <div class="apostila-body">
                        <div class="apostila-price"><div class="price">R$ ${ap.precoComEncadernacao.toFixed(2)}</div><div class="price-details">Impressão: R$ ${ap.precoImpressao.toFixed(2)}<br>Encadernação: R$ 7,00</div><div class="encadernacao-info"><div class="encadernacao-inclusa"><i class="fas fa-check"></i> ENCADERNAÇÃO INCLUSA</div><p>Capa Preta no Final, Capa Transparente, Encadernação na Esquerda, Espiral Preto</p></div>${obsHtml}</div>
                        <div class="apostila-actions"><button class="btn btn-buy add-catalog" data-id="${ap.id}"><i class="fas fa-cart-plus"></i> Adicionar</button><button class="btn btn-details view-details" data-id="${ap.id}"><i class="fas fa-info-circle"></i> Detalhes</button></div>
                    </div>
                `;
                container.appendChild(card);
            });
            document.querySelectorAll('.add-catalog').forEach(btn => btn.addEventListener('click', (e) => { adicionarItemCatalogo(btn.dataset.id); }));
            document.querySelectorAll('.view-details').forEach(btn => btn.addEventListener('click', (e) => { const item = apostilas.find(a => a.id === btn.dataset.id); mostrarDetalhesCatalogo(item); }));
        }

        function adicionarItemCatalogo(id) {
            const item = apostilas.find(a => a.id === id);
            if (!item) return;
            const existente = carrinho.find(i => i.id === id && i.tipo === 'catalogo');
            if (existente) existente.quantidade++;
            else carrinho.push({ ...item, tipoItem: 'catalogo', quantidade: 1, idUnico: `cat-${id}` });
            atualizarCarrinhoUI();
            mostrarFeedback(`${item.tipoNome} (${item.folhas} folhas) adicionado!`);
        }

        function adicionarItemCalculadora() {
            const tipo = document.getElementById('calc-tipo').value;
            const folhas = parseInt(document.getElementById('calc-folhas-range').value);
            const quantidade = parseInt(document.getElementById('calc-quantidade').value);
            const opFrente = document.getElementById('opt-frenteverso').checked;
            const opCapa = document.getElementById('opt-capacolorida').checked;
            let numOpcoes = (opFrente ? 1 : 0) + (opCapa ? 1 : 0);
            const calc = calcularApostilaCustom(tipo, folhas, quantidade, numOpcoes);
            let tipoTexto = '';
            switch(tipo) {
                case 'preta-frente': tipoTexto = 'Preta Só Frente'; break;
                case 'preta-fv': tipoTexto = 'Preta F/V'; break;
                case 'colorida-frente': tipoTexto = 'Colorida Só Frente'; break;
                case 'colorida-fv': tipoTexto = 'Colorida F/V'; break;
            }
            const opcoesTexto = numOpcoes ? ` +${numOpcoes} opção(ões)` : '';
            const novoItem = {
                idUnico: `custom-${Date.now()}-${Math.random()}`,
                tipoItem: 'custom',
                nome: `${tipoTexto} - ${folhas} folhas${opcoesTexto}`,
                folhas: folhas,
                quantidade: quantidade,
                precoUnitario: calc.precoUnitario,
                precoTotal: calc.precoTotal,
                detalhes: calc
            };
            carrinho.push(novoItem);
            atualizarCarrinhoUI();
            mostrarFeedback(`Apostila personalizada adicionada (${quantidade} unid.)`);
        }

        function mostrarDetalhesCatalogo(ap) {
            const modal = document.createElement('div');
            modal.style.cssText = 'position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.7); display:flex; align-items:center; justify-content:center; z-index:3000;';
            modal.innerHTML = `<div style="background:white; max-width:500px; width:90%; border-radius:12px; padding:2rem;"><button class="close-modal" style="float:right; font-size:1.5rem; background:none; border:none; cursor:pointer;">&times;</button><h3>${ap.tipoNome} - ${ap.folhas} folhas</h3><p>Preço por folha: R$ ${ap.precoPorFolha.toFixed(2)}<br>Impressão: R$ ${ap.precoImpressao.toFixed(2)}<br>Encadernação: R$ 7,00<br><strong>Total: R$ ${ap.precoComEncadernacao.toFixed(2)}</strong></p><button class="btn btn-buy add-from-modal" data-id="${ap.id}">Adicionar ao Carrinho</button></div>`;
            document.body.appendChild(modal);
            modal.querySelector('.close-modal').onclick = () => modal.remove();
            modal.querySelector('.add-from-modal').onclick = () => { adicionarItemCatalogo(ap.id); modal.remove(); };
        }

        function atualizarCarrinhoUI() {
            const cartCount = carrinho.reduce((acc, i) => acc + i.quantidade, 0);
            document.getElementById('cart-count').textContent = cartCount;
            const container = document.getElementById('cart-items');
            if (!container) return;
            if (carrinho.length === 0) { container.innerHTML = '<p style="text-align:center;">Carrinho vazio</p>'; document.getElementById('cart-subtotal').textContent = 'R$ 0,00'; document.getElementById('cart-total').textContent = 'R$ 0,00'; return; }
            let subtotal = 0;
            container.innerHTML = '';
            carrinho.forEach((item, idx) => {
                const precoTotalItem = item.tipoItem === 'catalogo' ? item.precoComEncadernacao * item.quantidade : item.precoTotal;
                subtotal += precoTotalItem;
                const div = document.createElement('div');
                div.className = 'cart-item';
                div.innerHTML = `
                    <div><strong>${item.tipoItem === 'catalogo' ? item.tipoNome : item.nome}</strong><br>${item.folhas} folhas | Quantidade: ${item.quantidade}<br>R$ ${(item.tipoItem === 'catalogo' ? item.precoComEncadernacao : item.precoUnitario).toFixed(2)} cada</div>
                    <div><button class="cart-qty-up" data-idx="${idx}">+</button><span style="margin:0 8px;">${item.quantidade}</span><button class="cart-qty-down" data-idx="${idx}">-</button><button class="cart-remove" data-idx="${idx}" style="margin-left:10px; background:#e53935; color:white; border:none; border-radius:4px; padding:4px 8px;"><i class="fas fa-trash"></i></button></div>
                `;
                container.appendChild(div);
            });
            document.getElementById('cart-subtotal').textContent = `R$ ${subtotal.toFixed(2)}`;
            document.getElementById('cart-total').textContent = `R$ ${subtotal.toFixed(2)}`;
            document.querySelectorAll('.cart-qty-up').forEach(btn => btn.addEventListener('click', (e) => { alterarQuantidadeCarrinho(parseInt(btn.dataset.idx), 1); }));
            document.querySelectorAll('.cart-qty-down').forEach(btn => btn.addEventListener('click', (e) => { alterarQuantidadeCarrinho(parseInt(btn.dataset.idx), -1); }));
            document.querySelectorAll('.cart-remove').forEach(btn => btn.addEventListener('click', (e) => { removerItemCarrinho(parseInt(btn.dataset.idx)); }));
        }

        function alterarQuantidadeCarrinho(idx, delta) {
            if (carrinho[idx]) {
                carrinho[idx].quantidade += delta;
                if (carrinho[idx].quantidade <= 0) carrinho.splice(idx, 1);
                else if (carrinho[idx].tipoItem === 'custom') carrinho[idx].precoTotal = carrinho[idx].precoUnitario * carrinho[idx].quantidade;
                atualizarCarrinhoUI();
            }
        }
        function removerItemCarrinho(idx) { carrinho.splice(idx, 1); atualizarCarrinhoUI(); mostrarFeedback('Item removido'); }

        function finalizarPedidoWhatsApp() {
            if (carrinho.length === 0) { mostrarFeedback('Carrinho vazio!'); return; }
            const termo = document.getElementById('aceito-termos-resumo');
            if (!termo.checked) { mostrarFeedback('Você precisa aceitar os termos e condições.'); return; }
            let mensagem = "Olá! Gostaria de solicitar o orçamento dos seguintes itens:%0A";
            let totalPedido = 0;
            carrinho.forEach(item => {
                const precoUnit = item.tipoItem === 'catalogo' ? item.precoComEncadernacao : item.precoUnitario;
                const subtotal = precoUnit * item.quantidade;
                totalPedido += subtotal;
                mensagem += `- ${item.tipoItem === 'catalogo' ? item.tipoNome : item.nome} | ${item.folhas} folhas | Quantidade: ${item.quantidade} | R$ ${precoUnit.toFixed(2)} cada = R$ ${subtotal.toFixed(2)}%0A`;
            });
            mensagem += `%0A*Total: R$ ${totalPedido.toFixed(2)}*%0A%0APrazo de entrega e forma de pagamento?`;
            const url = `https://wa.me/5513988089754?text=${mensagem}`;
            window.open(url, '_blank');
        }

        // ========== ATUALIZAR CALCULADORA ==========
        function atualizarCalculadoraUI() {
            const tipo = document.getElementById('calc-tipo').value;
            let folhas = parseInt(document.getElementById('calc-folhas-range').value);
            const quantidade = parseInt(document.getElementById('calc-quantidade').value);
            const opFrente = document.getElementById('opt-frenteverso').checked;
            const opCapa = document.getElementById('opt-capacolorida').checked;
            let numOpcoes = (opFrente ? 1 : 0) + (opCapa ? 1 : 0);
            document.getElementById('calc-folhas-input').value = folhas;
            document.getElementById('folhas-value').textContent = folhas;
            const resultado = calcularApostilaCustom(tipo, folhas, quantidade, numOpcoes);
            let tipoTexto = '';
            switch(tipo) {
                case 'preta-frente': tipoTexto = 'Preta - Só Frente'; break;
                case 'preta-fv': tipoTexto = 'Preta - Frente e Verso'; break;
                case 'colorida-frente': tipoTexto = 'Colorida - Só Frente'; break;
                case 'colorida-fv': tipoTexto = 'Colorida - Frente e Verso'; break;
            }
            document.getElementById('preco-calculado').textContent = `R$ ${resultado.precoTotal.toFixed(2)}`;
            document.getElementById('detalhes-calculadora').textContent = `${quantidade} × ${folhas} folhas (${tipoTexto}) ${numOpcoes > 0 ? `+ ${numOpcoes} opção(ões)` : ''}`;
            document.getElementById('preco-por-folha').textContent = resultado.precoPorFolha.toFixed(2);
            document.getElementById('custo-impressao').textContent = `R$ ${resultado.precoImpressao.toFixed(2)}`;
            document.getElementById('quantidade-apostilas').textContent = quantidade;
            document.getElementById('custo-total').textContent = `R$ ${resultado.precoTotal.toFixed(2)}`;
            const obsDiv = document.getElementById('observacao-capa-calculadora');
            obsDiv.style.display = tipo.includes('preta') ? 'block' : 'none';
        }

        // ========== FILTROS ==========
